{
    "id": "metasploit-lab",
    "name": "Metasploit Lab",
    "description": "Learn the basics of recon tools like NMap and using Metasploit to exploit and explore a vulnerable target",
    "hosts":[ 
        {
            "template": "kali-metasploit",
            "hostname": "kali",
            "description": "Linux distro with hacking tools. SSH login is root:kali",
            "networks": [
                "int"
            ],
            "port_forwards": [
                "tcp:127.0.0.1:22"
            ],
            "console": true
        },
        {
            "template": "tomcat-vuln",
            "hostname": "target",
            "description": "Target with unknown vulnerabilities",
            "hide_ip": true,
            "networks": [
                "int"
            ]
        }
    ],
    "networks": {
        "int": {
            "private": true
        }
    }
}
